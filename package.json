{
  "name": "@vectra/harness",
  "version": "0.1.0",
  "description": "ATP-native agentic execution harness for Reality Anchor",
  "type": "module",
  "main": "dist/src/core/job.js",
  "types": "dist/src/core/job.d.ts",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/src/index.js",
    "start:dev": "VECTRA_INSTANCE=instances/reality-anchor.instance.json node dist/src/index.js"
  },
  "keywords": [
    "atp",
    "agentic",
    "harness",
    "execution",
    "vectra"
  ],
  "author": "Reality Anchor",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "ws": "^8.20.0"
  }
}
