{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VectraInstance",
  "description": "Instance configuration for a Vectra deployment. Covers the ~40% of instance config that ATP protocols do not handle: transport, identity, operational tuning, model routing, and failover.",
  "type": "object",
  "required": ["instanceId", "atpPath", "models", "transport"],
  "properties": {
    "instanceId": {
      "type": "string",
      "description": "Unique instance identifier (e.g. reality-anchor, my-agent)"
    },
    "atpPath": {
      "type": "string",
      "description": "Absolute path to ATP instance directory"
    },
    "models": {
      "type": "object",
      "description": "Role-to-model assignment. Maps agent roles to concrete provider/model strings.",
      "properties": {
        "mainAgent": {
          "type": "string",
          "description": "Primary captain model (handles main session turns)"
        },
        "t1": {
          "type": "string",
          "description": "T1 scanner model (fast/cheap, drift detection)"
        },
        "t2": {
          "type": "string",
          "description": "T2 watcher model (balanced, correction application)"
        },
        "t3": {
          "type": "string",
          "description": "T3 validator model (capable, deep analysis and escalations)"
        },
        "fallback": {
          "type": "string",
          "description": "Fallback model when primary is unavailable"
        }
      },
      "required": ["mainAgent", "t1", "t2", "t3"],
      "additionalProperties": {
        "type": "string",
        "description": "Additional role-to-model assignments for custom roles"
      }
    },
    "transport": {
      "type": "object",
      "description": "Channel transport configuration",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["discord", "signal", "webhook", "cli"],
          "description": "Transport connector type"
        },
        "config": {
          "type": "object",
          "description": "Transport-specific config (tokens, guild IDs, channel mappings, etc.)"
        }
      },
      "required": ["type", "config"]
    },
    "autonomyLevel": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "description": "Autonomy level: 0=fully supervised, 4=bounded autonomous, 5=fully event-driven"
    },
    "costCeiling": {
      "type": "number",
      "description": "Max cost per task chain in USD before halt"
    },
    "timeoutMultiplier": {
      "type": "number",
      "description": "Global timeout multiplier applied to all protocol step durations"
    },
    "maxRecursionDepth": {
      "type": "integer",
      "description": "Max sub-agent recursion depth before hard stop"
    },
    "captainTwo": {
      "type": "object",
      "description": "Active/standby failover config (optional)",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "standbyEndpoint": {
          "type": "string",
          "description": "URL of the standby captain's Vectra proxy"
        },
        "heartbeatIntervalMs": {
          "type": "integer",
          "description": "Interval between heartbeat probes in milliseconds"
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "Per-provider API config. Keys are provider IDs (anthropic, openai, xai, vllm, openrouter).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "baseUrl": {
            "type": "string",
            "description": "Override default base URL (required for vLLM)"
          },
          "envVar": {
            "type": "string",
            "description": "Env var name for API key (overrides built-in default)"
          },
          "apiKey": {
            "type": "string",
            "description": "Direct API key (not recommended — use envVar instead)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "properties": {
    "scheduler": {
      "type": "object",
      "description": "Scheduler configuration for cron jobs and heartbeat checks",
      "properties": {
        "cronJobs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "schedule", "task", "channelId", "enabled"],
            "properties": {
              "id": { "type": "string" },
              "schedule": { "type": "string", "description": "Cron expression e.g. '0 9 * * *'" },
              "task": { "type": "string", "description": "Task description injected as message" },
              "channelId": { "type": "string" },
              "model": { "type": "string" },
              "enabled": { "type": "boolean" }
            }
          }
        },
        "heartbeat": {
          "type": "object",
          "properties": {
            "intervalMs": { "type": "integer", "description": "Heartbeat interval in milliseconds" },
            "prompt": { "type": "string", "description": "Heartbeat prompt to inject" },
            "channelId": { "type": "string" },
            "model": { "type": "string" },
            "quietHoursStart": { "type": "integer", "minimum": 0, "maximum": 23 },
            "quietHoursEnd": { "type": "integer", "minimum": 0, "maximum": 23 }
          }
        }
      }
    }
  }
}
